{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "CipherClip",
  "version": "0.1.4",
  "identifier": "com.cipherclip.core",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "CipherClip",
        "width": 450,
        "height": 500,
        "resizable": false,
        "fullscreen": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/your-username/cipherclip/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDU5NTZBQkVFNkY1RDUzMDkKUldRSlUxMXY3cXRXV1JjSWZmWTZDaW9mL2J3Tys1dXEyUDdVWmx4ZFpuM09lRGNtcTNuR2JiWm0K"
    }
  }
}
